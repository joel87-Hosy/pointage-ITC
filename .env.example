# URL publique de l'application (Render la fournit, ex: https://pointage-itc.onrender.com)
APP_URL=

# Clé de service Firebase (JSON compact sur une seule ligne)
# Obtenez-la dans Firebase Console > Paramètres > Comptes de service > Générer une clé
FIREBASE_SERVICE_ACCOUNT=

# Option locale plus simple : chemin vers le fichier JSON de clé Firebase
# Exemple: .\\firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_FILE=

# Accès interface admin (obligatoire pour /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Port (Render le définit automatiquement)
PORT=3000
